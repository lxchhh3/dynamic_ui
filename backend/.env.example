# Copy to backend/.env (gitignored) and fill in real values.
# Compose strict-env requires these to be set, not defaulted.

# Postgres — value also goes into POSTGRES_PASSWORD for the db service.
POSTGRES_PASSWORD=replace-with-a-strong-random-string
DATABASE_URL=postgresql+asyncpg://custom_ui:replace-with-a-strong-random-string@127.0.0.1:5433/custom_ui

# JWT signing — generate with `python -c "import secrets;print(secrets.token_urlsafe(48))"`
JWT_SECRET=replace-with-a-48+char-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO

# Hybrid LLM (Phase 6). Unset = feature off (deterministic text).
# On the VPS with the 5070Ti reverse tunnel: http://172.19.0.1:8001/render
# LLM_RENDER_URL=
